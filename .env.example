# Umami analytics. Both must be set or the tracker is omitted entirely from the build,
# so local dev and preview deploys never pollute your stats.
# HOST is the origin of your Umami instance, with no trailing slash.
PUBLIC_UMAMI_HOST=https://umami.daxrpm.dev
PUBLIC_UMAMI_ID=00000000-0000-0000-0000-000000000000

# Optional. Without it, scripts/fetch-github.mjs falls back to a public proxy for the
# contribution calendar (the REST API does not expose it). A classic PAT with `read:user`,
# or a fine-grained token with read access to public repositories, is enough.
GITHUB_TOKEN=
