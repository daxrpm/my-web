---
import { site } from '../data/profile';
import { ui } from '../i18n/ui';
import { t, localeUrl, otherLocale, localeNames, type Lang } from '../i18n/config';
import TechIcon from './TechIcon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const other = otherLocale(lang);
const github = site.socials.find((s) => s.name === 'GitHub')!.url;
---

<header class="sticky top-0 z-40 border-b border-line/70 bg-canvas/80 backdrop-blur">
  <nav class="wrap flex h-16 items-center justify-between" aria-label="Primary">
    <a
      href={localeUrl(lang)}
      class="font-mono text-sm font-medium text-fg transition-colors hover:text-accent"
    >
      {site.handle}<span class="text-accent">.</span>dev
    </a>

    <ul class="hidden items-center gap-7 text-sm sm:flex">
      {
        ui.nav.links.map((l) => (
          <li>
            <a
              href={l.href}
              class="text-fg-muted transition-colors hover:text-fg"
              data-umami-event="nav-click"
              data-umami-event-section={l.href.slice(1)}
            >
              {t(l.label, lang)}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      {/* A real link to a real URL, so it is crawlable and shareable — not a JS text swap. */}
      <a
        href={localeUrl(other)}
        id="lang-toggle"
        data-lang={other}
        hreflang={other}
        class="flex h-8 items-center rounded-md border border-line-hi px-2.5 font-mono text-xs uppercase text-fg-muted transition-colors hover:border-accent/60 hover:text-accent"
        aria-label={t(ui.nav.langToggle, lang)}
        title={localeNames[other]}
        data-umami-event="lang-toggle"
        data-umami-event-to={other}
      >
        {other}
      </a>

      <button
        type="button"
        id="theme-toggle"
        class="flex h-8 w-8 items-center justify-center rounded-md border border-line-hi text-fg-muted transition-colors hover:border-accent/60 hover:text-accent"
        aria-label={t(ui.nav.themeToggle, lang)}
        data-umami-event="theme-toggle"
      >
        {/* Both icons ship; CSS shows whichever matches the active theme. */}
        <svg class="icon-sun h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4" />
        </svg>
        <svg class="icon-moon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 14.5A8.5 8.5 0 0 1 9.5 4a8.5 8.5 0 1 0 10.5 10.5z" />
        </svg>
      </button>

      <a
        href={github}
        rel="noopener"
        class="flex items-center gap-2 rounded-md border border-line-hi px-3 py-1.5 text-sm text-fg-muted transition-colors hover:border-accent/60 hover:text-accent"
        data-umami-event="github-profile"
        data-umami-event-source="nav"
      >
        {/* Mono: the button already colours itself on hover, and the black GitHub mark
            would fight the accent. */}
        <TechIcon name="GitHub" class="h-4 w-4" mono />
        GitHub
      </a>
    </div>
  </nav>
</header>

<style>
  /* Show the icon for the theme you would switch *to*. */
  :root[data-theme='dark'] .icon-sun,
  :root[data-theme='light'] .icon-moon {
    display: none;
  }
</style>

<script>
  const root = document.documentElement;
  const meta = document.getElementById('theme-color');

  const paint = (theme: string) => {
    root.dataset.theme = theme;
    // Match the browser chrome to the page, or mobile Safari frames a dark page in white.
    meta?.setAttribute('content', theme === 'light' ? '#ffffff' : '#06080b');
    window.dispatchEvent(new CustomEvent('themechange', { detail: theme }));
  };

  // Dark unless the visitor chose light. The OS preference is not consulted.
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = root.dataset.theme === 'light' ? 'dark' : 'light';
    localStorage.setItem('theme', next);
    paint(next);
  });

  // Remember the language the visitor picked, so the auto-redirect never overrules them.
  const langToggle = document.getElementById('lang-toggle') as HTMLAnchorElement | null;
  langToggle?.addEventListener('click', () => {
    localStorage.setItem('lang', langToggle.dataset.lang ?? 'en');
  });
</script>
