---
import { experience, affiliation } from '../data/profile';
---

<section id="work" aria-labelledby="work-h" class="wrap py-16 sm:py-20">
  <h2 id="work-h" class="eyebrow">Work</h2>

  <ol class="mt-6 space-y-3">
    {
      experience.map((e) => (
        <li class="card bg-surface/80 p-5 backdrop-blur-sm sm:p-6">
          <div class="flex flex-wrap items-start gap-x-4 gap-y-2">
            {e.logo && (
              <img
                src={e.logo}
                alt=""
                loading="lazy"
                class="logo-mark mt-0.5 h-8 w-auto max-w-[4.5rem] shrink-0 object-contain object-left"
              />
            )}
            <div class="min-w-0 flex-1">
              <h3 class="font-semibold text-fg">{e.role}</h3>
              <p class="mt-0.5 text-sm text-fg-muted">{e.org}</p>
            </div>
            <span class="shrink-0 font-mono text-xs text-fg-subtle">{e.period}</span>
          </div>

          <p class="mt-4 text-sm leading-relaxed text-fg-muted">{e.note}</p>

          <ul class="mt-3 space-y-1.5">
            {e.points.map((pt) => (
              <li class="flex gap-2.5 text-sm leading-relaxed text-fg-subtle">
                <span class="mt-[0.45rem] h-1 w-1 shrink-0 rounded-full bg-accent/70" />
                <span>{pt}</span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>

  <p class="mt-6 text-sm text-fg-subtle">
    The CMS work is open —{' '}
    {
      affiliation.links.map((l, i) => (
        <>
          {i > 0 && <span aria-hidden="true"> · </span>}
          <a
            href={l.url}
            rel="noopener"
            class="link"
            data-umami-event="research-click"
            data-umami-event-repo={l.label}
          >
            {l.label}
          </a>
        </>
      ))
    }.
  </p>
</section>
