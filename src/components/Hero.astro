---
import { site } from '../data/profile';
import github from '../data/github.json';

const { stats } = github;

// Real, verifiable numbers. The previous build claimed "5+ Years Experience" and
// "20+ Projects" — these are both truer and larger.
const figures = [
  { value: stats.public_repos, label: 'public repos' },
  { value: stats.contributions_last_year.toLocaleString('en-US'), label: 'contributions, past year' },
  { value: `${new Date().getFullYear() - stats.coding_since}y`, label: `building in the open since ${stats.coding_since}` },
];
---

<section id="top" class="wrap pt-20 pb-16 sm:pt-28 sm:pb-20">
  <p class="eyebrow">{site.location}</p>

  <h1 class="mt-4 text-4xl font-bold tracking-tight text-fg sm:text-5xl">
    {site.name}
  </h1>

  <!-- The single sentence a language model will lift if it quotes this page at all. -->
  <p class="mt-4 max-w-2xl text-xl leading-relaxed text-fg sm:text-2xl">
    {site.tagline}
  </p>

  <p class="mt-5 max-w-2xl leading-relaxed text-fg-muted">
    Computer Science undergraduate at <span class="text-fg">Escuela Politécnica Nacional</span>, and a
    collaborator on the <span class="text-fg">CMS experiment at CERN</span>, where I work on machine learning
    for jet flavour tagging and dark matter search analyses. Outside the lab I write systems software in Rust
    and C — a PAM face-authentication module, a shell, zero-copy I/O benchmarks — and I care a lot about
    networks and security.
  </p>

  <ul class="mt-10 flex flex-wrap gap-x-10 gap-y-5">
    {
      figures.map((f) => (
        <li>
          <span class="block font-mono text-2xl font-medium text-accent">{f.value}</span>
          <span class="mt-0.5 block text-xs text-fg-subtle">{f.label}</span>
        </li>
      ))
    }
  </ul>

  <div class="mt-10 flex flex-wrap items-center gap-3">
    <a
      href="#work"
      class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-canvas transition-colors hover:bg-accent-hi"
      data-umami-event="cta-click"
      data-umami-event-cta="see-the-work"
    >
      See the work
    </a>
    <a
      href={`mailto:${site.email}`}
      class="rounded-md border border-line-hi px-4 py-2 text-sm font-medium text-fg-muted transition-colors hover:border-accent/60 hover:text-accent"
      data-umami-event="cta-click"
      data-umami-event-cta="get-in-touch"
    >
      Get in touch
    </a>
  </div>
</section>
