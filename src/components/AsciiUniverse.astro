---
/**
 * ASCII particle universe behind the hero. Two clusters fall together, collide, and
 * blow outward — scroll position drives the expansion, so the "big bang" plays as you
 * move down the page.
 *
 * Decorative only: it lives behind the text, is aria-hidden, and every word of the hero
 * is real HTML. If the canvas never boots (no JS, reduced motion, crawler) the page is
 * unchanged. That is the deal that keeps the AI-crawler win from the static rebuild.
 */
---

<canvas
  id="universe"
  aria-hidden="true"
  class="pointer-events-none absolute inset-0 h-full w-full opacity-0 transition-opacity duration-1000"
></canvas>

<script>
  const canvas = document.getElementById('universe') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d', { alpha: true })!;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Glyph ramp: sparse dots at the faint end, solid blocks at the hot core.
    const RAMP = '·:-=+*#%@';
    const COUNT = window.innerWidth < 768 ? 900 : 2200;

    type P = { x: number; y: number; z: number; vx: number; vy: number; vz: number; seed: number };
    const parts: P[] = [];

    /** Two offset clusters, so the particles read as a collision rather than one blob. */
    for (let i = 0; i < COUNT; i++) {
      const lobe = i % 2 === 0 ? -1 : 1;
      // Fibonacci sphere gives an even shell instead of a clumpy random one.
      const t = i / COUNT;
      const phi = Math.acos(1 - 2 * t);
      const theta = Math.PI * (1 + Math.sqrt(5)) * i;
      const r = 0.35 + Math.random() * 0.25;

      const x = Math.sin(phi) * Math.cos(theta) * r + lobe * 0.55;
      const y = Math.sin(phi) * Math.sin(theta) * r;
      const z = Math.cos(phi) * r;

      parts.push({
        x,
        y,
        z,
        // Outward velocity from the collision point, with a tangential swirl.
        vx: x * 0.8 - lobe * 0.35 - y * 0.4,
        vy: y * 0.8 + x * 0.4,
        vz: z * 0.8,
        seed: Math.random() * 6.28,
      });
    }

    let w = 0;
    let h = 0;
    let dpr = 1;

    const resize = () => {
      dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      w = canvas.clientWidth;
      h = canvas.clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    // Scroll drives the explosion: 0 = singularity, 1 = dispersed universe.
    let scroll = 0;
    const onScroll = () => {
      scroll = Math.min(1, window.scrollY / (window.innerHeight * 1.1));
    };

    const draw = (time: number) => {
      const t = time * 0.0001;
      ctx.clearRect(0, 0, w, h);

      // Off-centre to the right on wide screens so the mass sits beside the headline
      // rather than behind it; centred on mobile, where the text stacks over it.
      const wide = w >= 900;
      const cx = wide ? w * 0.74 : w / 2;
      const cy = h * 0.5;
      const scale = (wide ? Math.min(w * 0.52, h) : Math.min(w, h)) * 0.62;

      // Ease so the first pixels of scroll produce visible motion.
      const blast = Math.pow(scroll, 0.75);
      const expand = 0.55 + blast * 2.6;

      const ry = t * 0.6 + blast * 1.2;
      const cosY = Math.cos(ry);
      const sinY = Math.sin(ry);
      const rx = Math.sin(t * 0.4) * 0.25 + blast * 0.3;
      const cosX = Math.cos(rx);
      const sinX = Math.sin(rx);

      // Soft radial bloom behind the mass — gives the particles something to sit in,
      // instead of reading as noise on flat black.
      const glow = ctx.createRadialGradient(cx, cy, 0, cx, cy, scale * 2.1);
      const gi = Math.max(0, 0.5 - blast * 0.4);
      glow.addColorStop(0, `rgba(63,185,80,${(gi * 0.30).toFixed(3)})`);
      glow.addColorStop(0.45, `rgba(35,120,90,${(gi * 0.12).toFixed(3)})`);
      glow.addColorStop(1, 'rgba(13,17,23,0)');
      ctx.fillStyle = glow;
      ctx.fillRect(0, 0, w, h);

      ctx.font = '13px "JetBrains Mono", ui-monospace, monospace';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      for (let i = 0; i < parts.length; i++) {
        const p = parts[i];

        // Position = origin + outward velocity × blast, with a slow drift so it is never
        // fully still at the top of the page.
        const drift = reduced ? 0 : Math.sin(t * 2 + p.seed) * 0.02;
        let x = p.x + p.vx * blast * 1.4 + drift;
        let y = p.y + p.vy * blast * 1.4 + drift;
        let z = p.z + p.vz * blast * 1.4;

        // Distance from the collision point drives colour: white-hot at the core,
        // accent green through the body, deep green at the rim. Using depth for this
        // made every particle "hot" and the whole mass washed out to pale grey.
        const r3 = Math.sqrt(x * x + y * y + z * z);

        // rotate Y
        const x1 = x * cosY - z * sinY;
        const z1 = x * sinY + z * cosY;
        // rotate X
        const y1 = y * cosX - z1 * sinX;
        const z2 = y * sinX + z1 * cosX;

        // perspective
        const persp = 2.6 / (2.6 + z2 * expand);
        const sx = cx + x1 * expand * scale * persp;
        const sy = cy + y1 * expand * scale * persp;

        if (sx < -20 || sx > w + 20 || sy < -20 || sy > h + 20) continue;

        // Depth sets opacity (near particles read solid, far ones recede).
        const depth = Math.max(0, Math.min(1, (persp - 0.85) * 3.4));
        const fade = 1 - blast * 0.55;

        // Heat by radius: 1 at the core, 0 out at the rim. Cools as it expands.
        const heat = Math.max(0, Math.min(1, 1 - r3 / 1.15)) * Math.max(0.15, 1 - blast);

        const b = Math.min(1, (0.35 + heat * 0.65) * fade);
        if (b < 0.05) continue;

        const glyph = RAMP[Math.min(RAMP.length - 1, Math.floor(Math.pow(b, 0.8) * RAMP.length))];

        const r = Math.round(45 + heat * heat * 190);
        const g = Math.round(150 + heat * 100);
        const bl = Math.round(85 + heat * heat * 140);
        const alpha = (0.3 + depth * 0.45 + heat * 0.3) * fade;
        ctx.fillStyle = `rgba(${r},${g},${bl},${Math.min(1, alpha).toFixed(3)})`;
        ctx.fillText(glyph, sx, sy);
      }
    };

    let raf = 0;
    const loop = (time: number) => {
      draw(time);
      raf = requestAnimationFrame(loop);
    };

    resize();
    onScroll();
    canvas.classList.remove('opacity-0');

    if (reduced) {
      // One static frame: the shape, none of the motion.
      draw(0);
    } else {
      // Only animate while the hero is actually on screen.
      const io = new IntersectionObserver(([e]) => {
        if (e.isIntersecting && !raf) raf = requestAnimationFrame(loop);
        else if (!e.isIntersecting && raf) {
          cancelAnimationFrame(raf);
          raf = 0;
        }
      });
      io.observe(canvas);
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    window.addEventListener('resize', resize);
  }
</script>
