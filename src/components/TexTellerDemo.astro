---
/**
 * The pipeline, end to end: handwritten photo → LaTeX string → rendered equation.
 *
 * The rendered step is native MathML, not KaTeX. It costs zero JavaScript, renders in every
 * current browser, and — unlike an image of an equation — a crawler can read it. The MathML
 * is the one thing here not driven by profile.ts: it is markup, not copy.
 */
import { texTeller } from '../data/profile';
import { ui } from '../i18n/ui';
import { t, type Lang } from '../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<div class="mt-5 grid gap-3 sm:grid-cols-3">
  <figure class="sm:col-span-1">
    <span class="eyebrow">{t(ui.texteller.input, lang)}</span>
    <img
      src={texTeller.image}
      alt={t(texTeller.alt, lang)}
      loading="lazy"
      decoding="async"
      class="mt-2 w-full rounded-lg border border-line bg-white p-2"
    />
    <figcaption class="mt-2 text-xs text-fg-subtle">{t(texTeller.caption, lang)}</figcaption>
  </figure>

  <div class="sm:col-span-2 flex flex-col gap-3">
    <div>
      <span class="eyebrow">{t(ui.texteller.output, lang)}</span>
      <pre class="mt-2 overflow-x-auto rounded-lg border border-line bg-surface p-3.5 font-mono text-xs text-accent"><code>{texTeller.latex}</code></pre>
    </div>

    <div>
      <span class="eyebrow">{t(ui.texteller.rendered, lang)}</span>
      <div class="mt-2 flex min-h-[5rem] items-center justify-center rounded-lg border border-line bg-surface p-4 text-fg">
        <math display="block" xmlns="http://www.w3.org/1998/Math/MathML" style="font-size:1.35rem">
          <mfrac>
            <msqrt><mn>2</mn><mi>x</mi></msqrt>
            <mrow><mn>2</mn><mi>x</mi></mrow>
          </mfrac>
          <mo>=</mo>
          <munderover>
            <mo>&#x2211;</mo>
            <mrow><mi>i</mi><mo>=</mo><mn>0</mn></mrow>
            <mi>&#x221E;</mi>
          </munderover>
          <mrow>
            <mn>3</mn><mi>i</mi><mo>+</mo><mn>2</mn><mo>+</mo><mn>5</mn><mi>x</mi>
          </mrow>
        </math>
      </div>
    </div>
  </div>
</div>
