---
import { existsSync } from 'node:fs';
import { featured, secondary, type Project } from '../data/profile';
import github from '../data/github.json';
import TexTellerDemo from './TexTellerDemo.astro';

type Repo = {
  name: string; url: string; description: string | null;
  language: string | null; stars: number; pushed_at: string;
};

const byName = new Map<string, Repo>();
for (const r of [...github.all, ...github.cms] as Repo[]) byName.set(r.name, r);

/** Assets are optional — a project renders fine before its screenshots land. */
const has = (p?: string) => Boolean(p && existsSync(`public${p}`));

const items = featured.map((p: Project) => {
  const repo = byName.get(p.repo);
  return {
    ...p,
    media: (p.media ?? []).filter((m) => has(m.src)),
    video: p.video && has(p.video.webm) ? p.video : undefined,
    url: repo?.url ?? `https://github.com/${p.owner ?? 'daxrpm'}/${p.repo}`,
    stars: repo?.stars ?? 0,
    pushed_at: repo?.pushed_at,
  };
});

const featuredNames = new Set(featured.map((p) => p.repo));
const more = [
  ...secondary.map((n) => byName.get(n)),
  ...(github.recent as Repo[]).filter((r) => !featuredNames.has(r.name) && !secondary.includes(r.name as never)),
]
  .filter((r): r is Repo => Boolean(r))
  .slice(0, 12);

const TAGS: Record<Project['tag'], string> = {
  research: 'Physics · Numerics',
  systems: 'Systems',
  ai: 'AI / ML',
  backend: 'Backend',
};

const ago = (iso?: string) => {
  if (!iso) return null;
  const d = Math.floor((Date.now() - new Date(iso).getTime()) / 86_400_000);
  if (d < 1) return 'today';
  if (d < 30) return `${d}d ago`;
  if (d < 365) return `${Math.floor(d / 30)}mo ago`;
  return `${Math.floor(d / 365)}y ago`;
};
---

<section id="work" aria-labelledby="work-h" class="wrap py-16 sm:py-20">
  <h2 id="work-h" class="eyebrow">Selected work</h2>

  <div class="mt-8 space-y-14">
    {
      items.map((p) => (
        <article>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h3 class="text-xl font-semibold text-fg">
              <a
                href={p.url}
                rel="noopener"
                class="transition-colors hover:text-accent"
                data-umami-event="project-click"
                data-umami-event-project={p.repo}
                data-umami-event-tag={p.tag}
                data-umami-event-target="title"
              >
                {p.title}
              </a>
            </h3>
            <span class="eyebrow shrink-0">{TAGS[p.tag]}</span>
          </div>

          <p class="mt-2.5 max-w-3xl leading-relaxed text-fg-muted">{p.blurb}</p>

          <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
            <a
              href={p.url}
              rel="noopener"
              class="link"
              data-umami-event="project-click"
              data-umami-event-project={p.repo}
              data-umami-event-tag={p.tag}
              data-umami-event-target="source"
            >
              Source
            </a>
            {p.live && (
              <a
                href={p.live}
                rel="noopener"
                class="link"
                data-umami-event="project-click"
                data-umami-event-project={p.repo}
                data-umami-event-tag={p.tag}
                data-umami-event-target="live-demo"
              >
                Live demo
              </a>
            )}
            {p.stars > 0 && <span class="font-mono text-xs text-fg-subtle">★ {p.stars}</span>}
            {p.pushed_at && <span class="font-mono text-xs text-fg-subtle">updated {ago(p.pushed_at)}</span>}
            <span class="flex flex-wrap gap-1.5">
              {p.stack.map((s) => <span class="chip">{s}</span>)}
            </span>
          </div>

          {p.repo === 'TexTeller-Rust' && <TexTellerDemo />}

          {p.video && (
            <figure class="mt-5">
              <video
                class="w-full rounded-lg border border-line bg-black"
                src={p.video.webm}
                poster={p.video.poster}
                autoplay
                muted
                loop
                playsinline
                preload="none"
                aria-label={p.video.caption}
              >
                <source src={p.video.webm} type="video/webm" />
                <source src={p.video.mp4} type="video/mp4" />
              </video>
              <figcaption class="mt-2 text-xs text-fg-subtle">{p.video.caption}</figcaption>
            </figure>
          )}

          {p.media.length > 0 && (
            /* CSS scroll-snap: a real gallery with no carousel JavaScript. */
            <div class="mt-5 -mx-5 flex snap-x snap-mandatory gap-4 overflow-x-auto px-5 pb-3 sm:mx-0 sm:px-0">
              {p.media.map((m) => (
                <figure class="w-[85%] shrink-0 snap-start sm:w-[48%]">
                  <img
                    src={m.src}
                    alt={m.alt}
                    loading="lazy"
                    decoding="async"
                    class="w-full rounded-lg border border-line bg-canvas"
                  />
                  {m.caption && <figcaption class="mt-2 text-xs leading-relaxed text-fg-subtle">{m.caption}</figcaption>}
                </figure>
              ))}
            </div>
          )}

          {p.terminal && (
            <pre class="mt-5 overflow-x-auto rounded-lg border border-line bg-surface p-4 font-mono text-xs leading-relaxed text-fg-muted"><code>{p.terminal.join('\n')}</code></pre>
          )}
        </article>
      ))
    }
  </div>

  <h3 class="eyebrow mt-16">Also on GitHub</h3>
  <ul class="mt-5 grid gap-3 sm:grid-cols-2">
    {
      more.map((r) => (
        <li class="card p-4">
          <a
            href={r.url}
            rel="noopener"
            class="group block"
            data-umami-event="repo-click"
            data-umami-event-repo={r.name}
          >
            <div class="flex items-baseline justify-between gap-3">
              <span class="font-mono text-sm text-fg transition-colors group-hover:text-accent">{r.name}</span>
              {r.stars > 0 && <span class="shrink-0 font-mono text-xs text-fg-subtle">★ {r.stars}</span>}
            </div>
            {r.description && <p class="mt-1.5 line-clamp-2 text-sm text-fg-muted">{r.description}</p>}
            {r.language && <span class="mt-2.5 block font-mono text-xs text-fg-subtle">{r.language}</span>}
          </a>
        </li>
      ))
    }
  </ul>

  <p class="mt-6 text-sm text-fg-subtle">
    This list updates itself from the GitHub API.{' '}
    <a
      href="https://github.com/daxrpm?tab=repositories"
      rel="noopener"
      class="link"
      data-umami-event="github-profile"
      data-umami-event-source="all-repos"
    >
      See all {github.stats.public_repos} repositories
    </a>.
  </p>
</section>
