---
import { skills, stackNote } from '../data/profile';
import { ui } from '../i18n/ui';
import { t, type Lang } from '../i18n/config';
import github from '../data/github.json';
import TechChip from './TechChip.astro';
import TechIcon from './TechIcon.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const langs = github.stats.languages;
const max = Math.max(...langs.map((l) => l.count));
---

<section id="stack" aria-labelledby="stack-h" class="wrap py-16 sm:py-20">
  <h2 id="stack-h" class="eyebrow">{t(ui.stack.heading, lang)}</h2>
  <p class="mt-3 max-w-2xl text-fg-muted">{t(stackNote, lang)}</p>

  <div class="mt-10 grid gap-x-10 gap-y-8 sm:grid-cols-2">
    {
      skills.map((g) => (
        <div>
          <h3 class="text-sm font-semibold text-fg">{t(g.group, lang)}</h3>
          <ul class="mt-3 flex flex-wrap gap-1.5">
            {g.items.map((s) => (
              <li class="contents">
                <TechChip name={s} />
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <h3 class="mt-14 text-sm font-semibold text-fg">{t(ui.stack.languages, lang)}</h3>
  <ul class="mt-4 space-y-2">
    {
      langs.map((l) => (
        <li class="flex items-center gap-3">
          <span class="flex w-32 shrink-0 items-center gap-2 font-mono text-xs text-fg-muted">
            <TechIcon name={l.name} class="h-4 w-4" />
            <span class="truncate">{l.name}</span>
          </span>
          <span class="h-1.5 flex-1 overflow-hidden rounded-full bg-surface">
            <span class="block h-full rounded-full bg-accent-dim" style={`width:${(l.count / max) * 100}%`} />
          </span>
          <span class="w-8 shrink-0 text-right font-mono text-xs text-fg-subtle">{l.count}</span>
        </li>
      ))
    }
  </ul>
</section>
