---
/**
 * A scroll-driven ASCII journey behind the entire page.
 *
 *   Milky Way  →  a black hole  →  the Solar System (a tour: Sun, then each planet)
 *              →  home, at Earth
 *
 * One fixed full-viewport canvas; scroll progress through the document (0..1) is the
 * only input. Scenes cross-fade, so it reads as one continuous flight.
 *
 * Decorative: aria-hidden, behind the content, and every word on the page is real HTML.
 * If this never boots — no JS, reduced motion, a crawler — the site is unchanged.
 */
---

<canvas id="cosmos" aria-hidden="true"></canvas>

<style>
  #cosmos {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1.2s ease;
  }
  #cosmos.ready {
    opacity: 1;
  }
</style>

<script>
  const canvas = document.getElementById('cosmos') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d', { alpha: true })!;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const RAMP = '.·:-=+*#%@';
    const glyph = (b: number) =>
      RAMP[Math.max(0, Math.min(RAMP.length - 1, Math.round(b * (RAMP.length - 1))))];

    let W = 0, H = 0, DPR = 1, MOBILE = false;
    const resize = () => {
      DPR = Math.min(window.devicePixelRatio || 1, 1.5);
      W = window.innerWidth;
      H = window.innerHeight;
      MOBILE = W < 768;
      canvas.width = W * DPR;
      canvas.height = H * DPR;
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
    };
    resize();

    const put = (x: number, y: number, b: number, c: number[], a: number) => {
      if (a < 0.015 || x < -14 || x > W + 14 || y < -14 || y > H + 14) return;
      ctx.fillStyle = `rgba(${c[0]},${c[1]},${c[2]},${a.toFixed(3)})`;
      ctx.fillText(glyph(b), x, y);
    };

    /* ── geometry ───────────────────────────────────────────────────────────── */

    /** Evenly distributed points on a unit sphere. */
    const fib = (n: number) =>
      Array.from({ length: n }, (_, i) => {
        const t = (i + 0.5) / n;
        const phi = Math.acos(1 - 2 * t);
        const th = Math.PI * (1 + Math.sqrt(5)) * i;
        return {
          x: Math.sin(phi) * Math.cos(th),
          y: Math.cos(phi),
          z: Math.sin(phi) * Math.sin(th),
          lat: 90 - (phi * 180) / Math.PI,
          lon: (((th * 180) / Math.PI) % 360) - 180,
        };
      });

    /**
     * Level-of-detail sphere shells. A planet 6px across needs ~40 glyphs; the same
     * planet filling the screen needs thousands. Picking the shell by apparent radius
     * keeps every planet densely filled with ASCII without melting the frame budget.
     */
    // The top shell exists for the close passes (Jupiter, and Earth filling the screen);
    // without it a big sphere thins out into scattered dots instead of solid ASCII.
    const LODS = [fib(48), fib(160), fib(420), fib(1100), fib(2600), fib(MOBILE ? 3600 : 7000)];
    const lodFor = (r: number) => {
      const want = r * r * 0.55; // glyphs needed to cover a disc of radius r
      for (const s of LODS) if (s.length >= want) return s;
      return LODS[LODS.length - 1];
    };

    /**
     * Draws a lit, densely-populated ASCII sphere.
     * `tex` shades a point by its lat/lon, which is what gives each planet a surface
     * (Jupiter's bands, Earth's continents, Mars's poles) rather than a flat ball.
     */
    const sphere = (
      cx: number, cy: number, r: number, spin: number,
      col: number[], alpha: number,
      tex?: (lat: number, lon: number) => number,
      /** Per-point colour, so Earth can be blue ocean and green land on one sphere. */
      colFn?: (lat: number, lon: number) => number[],
    ) => {
      if (r < 1.2 || alpha < 0.02) return;
      const pts = lodFor(r);
      const cs = Math.cos(spin), sn = Math.sin(spin);
      const tl = -0.4, ct = Math.cos(tl), st = Math.sin(tl);

      for (const p of pts) {
        const x1 = p.x * cs - p.z * sn;
        const z1 = p.x * sn + p.z * cs;
        const y1 = p.y * ct - z1 * st;
        const z2 = p.y * st + z1 * ct;
        if (z2 < -0.06) continue; // back face

        // Lit from the upper-left, toward the viewer: gives a terminator, not a flat disc.
        const light = Math.max(0, -x1 * 0.42 + y1 * 0.3 + z2 * 0.86);
        const shade = tex ? tex(p.lat, p.lon) : 1;
        const b = Math.min(1, (0.18 + light * 0.92) * shade);
        put(cx + x1 * r, cy + y1 * r, b, colFn ? colFn(p.lat, p.lon) : col, Math.min(1, (0.3 + light * 0.95) * alpha));
      }
    };

    /* ── scene data ─────────────────────────────────────────────────────────── */

    const N_GAL = MOBILE ? 1100 : 2400;
    const N_STAR = MOBILE ? 200 : 450;
    const N_DISK = MOBILE ? 900 : 2000;
    const N_HALO = MOBILE ? 500 : 1100;

    /** Milky Way: four logarithmic spiral arms on a tilted disc, plus a dense core. */
    const galaxy = Array.from({ length: N_GAL }, (_, i) => {
      const core = i < N_GAL * 0.18;
      const r = core ? Math.pow(Math.random(), 2) * 0.28 : 0.18 + Math.pow(Math.random(), 0.7) * 1.05;
      const arm = Math.floor(Math.random() * 4) * (Math.PI / 2);
      const a = arm + r * 2.9 + (Math.random() - 0.5) * (core ? 6.3 : 0.55);
      return {
        r, a,
        y: (Math.random() - 0.5) * (core ? 0.22 : 0.06),
        b: core ? 0.75 + Math.random() * 0.25 : 0.25 + Math.random() * 0.6,
        hot: core ? 1 : Math.random() * 0.5,
        spin: 0.35 + Math.random() * 0.25,
      };
    });

    const stars = Array.from({ length: N_STAR }, () => ({
      x: (Math.random() - 0.5) * 3,
      y: (Math.random() - 0.5) * 3,
      z: (Math.random() - 0.5) * 3,
      b: 0.2 + Math.random() * 0.8,
    }));

    /** Gargantua: a near edge-on accretion disc, plus the lensed halo over the shadow. */
    const disk = Array.from({ length: N_DISK }, () => {
      const r = 1.25 + Math.pow(Math.random(), 1.7) * 2.6; // in units of the shadow radius
      return { r, a: Math.random() * 6.283, b: 0.35 + Math.random() * 0.65, w: 1 / Math.pow(r, 1.4) };
    });
    // The halo is the light from the far side of the disc, bent up and over the hole —
    // the ring that makes the Interstellar image read as a black hole and not a planet.
    const halo = Array.from({ length: N_HALO }, () => ({
      th: Math.random() * 6.283,
      r: 1.02 + Math.pow(Math.random(), 2.2) * 0.5,
      b: 0.4 + Math.random() * 0.6,
    }));

    /** Simple procedural surfaces, so each planet is recognisable rather than a blob. */
    const bands = (n: number, depth: number) => (lat: number) =>
      1 - depth * 0.5 * (1 + Math.sin(lat * n * 0.11));
    const LAND: [number, number, number, number][] = [
      [50, -100, 26, 32], [15, -90, 9, 9], [-15, -60, 26, 13], [5, 20, 33, 20],
      [50, 18, 14, 22], [45, 95, 26, 48], [20, 78, 11, 11], [0, 115, 9, 16],
      [-25, 134, 13, 19], [72, -42, 9, 14], [-82, 0, 9, 180],
    ];
    const isLand = (lat: number, lon: number) =>
      LAND.some(([la, lo, dla, dlo]) => {
        let dl = Math.abs(lon - lo);
        if (dl > 180) dl = 360 - dl;
        return ((lat - la) / dla) ** 2 + (dl / dlo) ** 2 < 1;
      });

    // Earth: green land on blue ocean, on one sphere.
    const EARTH_TEX = (lat: number, lon: number) => (isLand(lat, lon) ? 1.05 : 0.72);
    const EARTH_COL = (lat: number, lon: number) =>
      isLand(lat, lon) ? [104, 196, 118] : [64, 132, 220];

    type Body = {
      name: string; r: number; size: number; speed: number; col: number[];
      ring?: boolean;
      tex?: (lat: number, lon: number) => number;
      colFn?: (lat: number, lon: number) => number[];
    };
    const SUN: Body = { name: 'Sun', r: 0, size: 5.2, speed: 0, col: [255, 226, 150] };
    const PLANETS: Body[] = [
      { name: 'Mercury', r: 0.32, size: 0.9, speed: 1.60, col: [172, 168, 158], tex: (la, lo) => 0.75 + 0.25 * Math.sin(la * 0.3 + lo * 0.2) },
      { name: 'Venus',   r: 0.45, size: 1.5, speed: 1.18, col: [235, 198, 126], tex: bands(3, 0.35) },
      { name: 'Earth',   r: 0.58, size: 1.6, speed: 1.00, col: [64, 132, 220], tex: EARTH_TEX, colFn: EARTH_COL },
      { name: 'Mars',    r: 0.75, size: 1.2, speed: 0.80, col: [214, 106, 66], tex: (la) => (Math.abs(la) > 72 ? 1.35 : 0.85 + 0.15 * Math.sin(la * 0.2)) },
      { name: 'Jupiter', r: 1.05, size: 3.6, speed: 0.44, col: [219, 184, 142], tex: bands(9, 0.5) },
      { name: 'Saturn',  r: 1.32, size: 3.1, speed: 0.32, col: [230, 212, 162], ring: true, tex: bands(7, 0.38) },
      { name: 'Uranus',  r: 1.56, size: 2.2, speed: 0.23, col: [150, 214, 220], tex: bands(4, 0.22) },
      { name: 'Neptune', r: 1.76, size: 2.1, speed: 0.18, col: [96, 122, 218], tex: bands(5, 0.3) },
    ];

    /** The tour: the Sun, then straight out through every planet, ending back at Earth. */
    const EARTH = PLANETS[2];
    const STOPS: Body[] = [SUN, ...PLANETS, EARTH];

    /* ── scroll ─────────────────────────────────────────────────────────────── */

    let p = 0, pTarget = 0;
    const readScroll = () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      pTarget = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
    };

    const smooth = (e0: number, e1: number, v: number) => {
      const t = Math.min(1, Math.max(0, (v - e0) / (e1 - e0)));
      return t * t * (3 - 2 * t);
    };
    const win = (x: number, a: number, b: number, f = 0.05) =>
      smooth(a - f, a + f, x) * (1 - smooth(b - f, b + f, x));

    // Scene boundaries. Black hole now sits between the galaxy and the solar system.
    const GAL: [number, number] = [-0.1, 0.20];
    const BH: [number, number] = [0.22, 0.42];
    const SOL: [number, number] = [0.44, 0.86];
    const EAR: [number, number] = [0.88, 1.2];

    /* ── render ─────────────────────────────────────────────────────────────── */

    const draw = (time: number) => {
      const t = time * 0.001;
      ctx.clearRect(0, 0, W, H);

      const cx = W >= 1024 ? W * 0.68 : W / 2;
      const cy = H / 2;
      const S = Math.hypot(W, H);
      const vis = 1 - win(p, 0.06, 1.1, 0.05) * 0.42;

      ctx.font = `${MOBILE ? 10 : 12}px "JetBrains Mono", ui-monospace, monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      const wGal = win(p, ...GAL);
      const wBh = win(p, ...BH);
      const wSol = win(p, ...SOL);
      const wEar = win(p, ...EAR);

      /* deep field */
      for (const s of stars) {
        const z = s.z + 1.8 - p * 0.6;
        if (z < 0.15) continue;
        const k = 1.1 / z;
        put(cx + s.x * k * S * 0.5, cy + s.y * k * S * 0.5, s.b * 0.5, [190, 220, 210], s.b * 0.22 * vis);
      }

      /* ── Milky Way ── */
      if (wGal > 0.01) {
        const lp = Math.min(1, Math.max(0, p / GAL[1]));
        const zoom = 0.55 + lp * 1.5;
        const tilt = 1.15 - lp * 0.55;
        const ct = Math.cos(tilt), st = Math.sin(tilt);
        for (const g of galaxy) {
          const a = g.a + t * 0.05 * g.spin;
          const x = Math.cos(a) * g.r, z = Math.sin(a) * g.r;
          const y2 = g.y * ct - z * st;
          const z2 = g.y * st + z * ct;
          const k = 2.2 / (2.2 + z2 * 0.8);
          put(
            cx + x * zoom * S * 0.34 * k,
            cy + y2 * zoom * S * 0.34 * k,
            g.b,
            g.hot > 0.5 ? [225, 235, 245] : [80, 200, 140],
            g.b * 0.8 * wGal * vis,
          );
        }
      }

      /* ── Black hole (Gargantua) ── */
      if (wBh > 0.01) {
        const lp = smooth(BH[0], BH[1], p);
        const hr = (0.10 + lp * 0.06) * S; // shadow radius grows as you approach
        const tilt = 0.10 + lp * 0.05;     // near edge-on — the disc is a blade, not a ring
        const spin = t * 0.35;

        // Accretion disc. Doppler beaming: the side rotating toward us is far brighter.
        for (const d of disk) {
          const a = d.a + spin * d.w * 2.2;
          const sx = cx + Math.cos(a) * d.r * hr;
          const sy = cy + Math.sin(a) * d.r * hr * tilt;
          const beam = 0.25 + 0.75 * Math.pow(Math.max(0, Math.cos(a - 1.57)), 0.7);
          const heat = Math.min(1, (1.5 / d.r) * (0.5 + beam));
          const col = [255, Math.round(140 + heat * 110), Math.round(50 + heat * 150)];
          put(sx, sy, Math.min(1, d.b * (0.35 + beam)), col, Math.min(1, d.b * beam * 1.15) * wBh * vis);
        }

        // Lensed halo: the far side of the disc, bent up and over the shadow.
        for (const h of halo) {
          const th = h.th + spin * 0.25;
          const sx = cx + Math.cos(th) * h.r * hr;
          const sy = cy + Math.sin(th) * h.r * hr;
          // Strongest above and below, where the equatorial disc is not already covering.
          const edge = Math.pow(Math.abs(Math.sin(th)), 0.55);
          const beam = 0.45 + 0.55 * Math.pow(Math.max(0, Math.cos(th - 1.57)), 0.6);
          const a = h.b * edge * beam * 1.25 * wBh * vis;
          put(sx, sy, Math.min(1, h.b * edge + 0.25), [255, 205, 140], a);
        }

        // Punch the event horizon out of everything drawn so far.
        ctx.globalCompositeOperation = 'destination-out';
        ctx.beginPath();
        ctx.arc(cx, cy, hr * 0.985, 0, 6.283);
        ctx.fill();
        ctx.globalCompositeOperation = 'source-over';

        // Photon ring: the hard, bright edge of the shadow.
        const steps = MOBILE ? 130 : 260;
        for (let i = 0; i < steps; i++) {
          const a = (i / steps) * 6.283;
          put(cx + Math.cos(a) * hr, cy + Math.sin(a) * hr, 1, [255, 226, 178], 0.95 * wBh * vis);
        }
      }

      /* ── Solar System: one continuous glide out through the planets ── */
      if (wSol > 0.01) {
        const tilt = 0.42;

        // Where a body sits, in system coordinates.
        const posOf = (b: Body) => {
          if (b.r === 0) return { x: 0, y: 0 };
          const a = t * b.speed * 0.18 + PLANETS.indexOf(b) * 1.7;
          return { x: Math.cos(a) * b.r, y: Math.sin(a) * b.r * tilt };
        };

        // A single, constant magnification for the whole tour. The camera simply drifts
        // from body to body — no zoom pumping in and out at every stop.
        const zoom = 2.5;
        const R = S * 0.30 * zoom;

        const q = smooth(SOL[0], SOL[1], p) * (STOPS.length - 1);
        const i0 = Math.min(STOPS.length - 1, Math.floor(q));
        const i1 = Math.min(STOPS.length - 1, i0 + 1);
        // Ease within each leg so arrivals and departures glide rather than jerk, but the
        // magnification never changes — the motion is a pan, not a dolly.
        const f = smooth(0, 1, q - i0);

        const a0 = posOf(STOPS[i0]);
        const a1 = posOf(STOPS[i1]);
        const focus = f < 0.5 ? STOPS[i0] : STOPS[i1];
        const camX = a0.x + (a1.x - a0.x) * f;
        const camY = a0.y + (a1.y - a0.y) * f;

        const px = (x: number) => cx + (x - camX) * R;
        const py = (y: number) => cy + (y - camY) * R;

        // Orbit rings: the track the camera is flying along.
        for (const b of PLANETS) {
          const steps = MOBILE ? 120 : 300;
          for (let i = 0; i < steps; i++) {
            const a = (i / steps) * 6.283;
            put(px(Math.cos(a) * b.r), py(Math.sin(a) * b.r * tilt), 0.25, [80, 150, 120], 0.3 * wSol * vis);
          }
        }

        // Bodies scale with the projection, not just with `zoom` — otherwise flying up to
        // a planet leaves it the same handful of pixels across.
        const K = MOBILE ? 0.055 : 0.045;

        sphere(px(0), py(0), SUN.size * R * K, t * 0.05, SUN.col, wSol * vis);

        for (const b of PLANETS) {
          const pos = posOf(b);
          const sx = px(pos.x), sy = py(pos.y);
          const rad = b.size * R * K;
          // The body being visited is the subject of the shot; the rest sit back a little.
          const near = focus === b ? 1 : 0.72;
          sphere(sx, sy, rad, t * 0.12 + PLANETS.indexOf(b), b.col, wSol * vis * near, b.tex, b.colFn);

          if (b.ring) {
            const steps = MOBILE ? 90 : 260;
            for (let i = 0; i < steps; i++) {
              const a = (i / steps) * 6.283;
              const rr = rad * (1.45 + (i % 4) * 0.16);
              put(sx + Math.cos(a) * rr, sy + Math.sin(a) * rr * 0.3, 0.55, [235, 218, 172], 0.75 * wSol * vis);
            }
          }
        }
      }

      /* ── Earth: home ── */
      if (wEar > 0.01) {
        const lp = smooth(EAR[0], 1, p);
        sphere(cx, cy, (0.17 + lp * 0.13) * S, t * 0.05 + 2.2, EARTH.col, wEar * vis, EARTH_TEX, EARTH_COL);
      }
    };

    /* ── loop ───────────────────────────────────────────────────────────────── */

    let raf = 0, running = false;
    const loop = (time: number) => {
      // Recomputed every frame: lazy images grow the document after load, which silently
      // shifts what any given scrollY means.
      readScroll();
      p += (pTarget - p) * 0.08;
      draw(time);
      raf = requestAnimationFrame(loop);
    };

    readScroll();
    p = pTarget;
    canvas.classList.add('ready');

    if (reduced) {
      draw(0);
    } else {
      const start = () => { if (!running) { running = true; raf = requestAnimationFrame(loop); } };
      const stop = () => { running = false; cancelAnimationFrame(raf); };
      start();
      document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));
    }

    window.addEventListener('resize', () => {
      resize();
      readScroll();
      if (reduced) draw(0);
    });
  }
</script>
