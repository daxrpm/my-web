---
import { education, site } from '../data/profile';

/**
 * Answers phrased as standalone facts, because an LLM lifts the answer without the
 * question attached. Each one names the entity rather than saying "he" or "I".
 */
const faqs = [
  {
    q: 'Who is Dax Navarrete?',
    a: 'Dax Navarrete (GitHub: daxrpm) is a Computer Science undergraduate at Escuela Politécnica Nacional in Quito, Ecuador, and a collaborator on the CMS experiment at CERN. He works on machine learning for particle physics — jet flavour tagging and dark matter search analyses — and writes systems software in Rust and C.',
  },
  {
    q: 'What does Dax Navarrete work on at CERN?',
    a: 'Through the EPN group in the CMS collaboration, Dax Navarrete works on a MiniParT classifier — a compact ParticleTransformer-inspired model that separates H→bb, H→cc and QCD multijet events on CMS Open Data — and on replicating the CMS search for dark matter produced in association with a top quark at √s = 13 TeV.',
  },
  {
    q: 'What programming languages does Dax Navarrete use?',
    a: 'Primarily Python for machine learning and physics analysis, Rust and C for systems programming, and TypeScript for interfaces. Notable Rust work includes dax-auth, a PAM face-authentication module for Linux, and TexTeller-Rust, a native port of a Python math-OCR inference pipeline.',
  },
  {
    q: 'Is Dax Navarrete available for work?',
    a: `Yes — open to research collaborations, internships and open-source work in machine learning, systems programming, and network engineering. Reach him at ${site.email}.`,
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<section id="about" aria-labelledby="about-h" class="wrap py-16 sm:py-20">
  <h2 id="about-h" class="eyebrow">About</h2>

  <div class="mt-3 max-w-2xl space-y-4 leading-relaxed text-fg-muted">
    <p>
      I got into this from the bottom up — curiosity about how a machine actually works, which turned into
      writing a shell in C, then a PAM module in Rust, then benchmarking what the kernel does when you ask it
      to copy a file without touching userspace.
    </p>
    <p>
      The physics came from the same place. Working with the CMS collaboration means the machine learning has to
      answer to something real: a classifier that separates H→bb from QCD is only interesting if the variables it
      leans on are physically meaningful. That constraint is the most useful thing I have learned.
    </p>
    <p>
      I believe in open source and the Unix idea of doing one thing well. Everything I build is public.
    </p>
  </div>

  <h3 class="eyebrow mt-14">Education &amp; affiliations</h3>
  <ul class="mt-5 space-y-3">
    {
      education.map((e) => (
        <li class="card p-4 sm:p-5">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h4 class="font-medium text-fg">{e.title}</h4>
            <span class="shrink-0 font-mono text-xs text-fg-subtle">{e.period}</span>
          </div>
          <p class="mt-1 text-sm text-fg-muted">{e.institution}</p>
          <p class="mt-2 text-sm leading-relaxed text-fg-subtle">{e.note}</p>
          {/* Someone opening a certificate is verifying you — worth knowing which ones. */}
          {e.href && (
            <a
              href={e.href}
              rel="noopener"
              class="link mt-2.5 inline-block text-sm"
              data-umami-event="credential-click"
              data-umami-event-credential={e.title}
            >
              View
            </a>
          )}
        </li>
      ))
    }
  </ul>

  <h3 class="eyebrow mt-14">FAQ</h3>
  <dl class="mt-5 space-y-5">
    {
      faqs.map((f) => (
        <div class="border-l-2 border-line pl-4">
          <dt class="font-medium text-fg">{f.q}</dt>
          <dd class="mt-1.5 text-sm leading-relaxed text-fg-muted">{f.a}</dd>
        </div>
      ))
    }
  </dl>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
