---
import { about } from '../data/profile';
import { ui } from '../i18n/ui';
import { t, type Lang } from '../i18n/config';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const faqs = t(about.faqs, lang);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: lang,
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<section id="about" aria-labelledby="about-h" class="wrap py-16 sm:py-20">
  <h2 id="about-h" class="eyebrow">{t(ui.about.heading, lang)}</h2>

  <div class="mt-3 max-w-2xl space-y-4 leading-relaxed text-fg-muted">
    {t(about.body, lang).map((p) => <p>{p}</p>)}
  </div>

  <h3 class="eyebrow mt-14">{t(ui.about.faqHeading, lang)}</h3>
  <dl class="mt-5 space-y-5">
    {
      faqs.map((f) => (
        <div class="border-l-2 border-line pl-4">
          <dt class="font-medium text-fg">{f.q}</dt>
          <dd class="mt-1.5 text-sm leading-relaxed text-fg-muted">{f.a}</dd>
        </div>
      ))
    }
  </dl>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
