---
import { affiliation, education, experience } from '../data/profile';
---

<section id="research" aria-labelledby="research-h" class="wrap py-16 sm:py-20">
  <h2 id="research-h" class="eyebrow">Research &amp; education</h2>

  <!-- The CERN affiliation, stated once and given room, instead of two repo tiles. -->
  <article class="mt-6 rounded-lg border border-accent/25 bg-gradient-to-b from-accent/[0.06] to-transparent p-6 sm:p-7">
    <div class="flex flex-wrap items-center gap-4">
      <div class="flex gap-2">
        {
          affiliation.logos.map((l) => (
            <span class="flex h-11 w-11 items-center justify-center rounded-md bg-white p-1.5">
              <img src={l.src} alt={l.alt} class="max-h-full max-w-full object-contain" loading="lazy" />
            </span>
          ))
        }
      </div>
      <div class="min-w-0">
        <h3 class="text-lg font-semibold text-fg">{affiliation.org}</h3>
        <p class="mt-0.5 text-sm text-fg-muted">{affiliation.role}</p>
      </div>
      <span class="ml-auto shrink-0 rounded-full border border-accent/40 px-2.5 py-1 font-mono text-xs text-accent">
        {affiliation.period}
      </span>
    </div>

    <p class="mt-5 leading-relaxed text-fg-muted">{affiliation.body}</p>

    <div class="mt-5 flex flex-wrap gap-x-5 gap-y-2 text-sm">
      {
        affiliation.links.map((l) => (
          <a
            href={l.url}
            rel="noopener"
            class="link"
            data-umami-event="research-click"
            data-umami-event-repo={l.label}
          >
            {l.label}
          </a>
        ))
      }
    </div>
  </article>

  {
    experience.length > 0 && (
      <>
        <h3 class="eyebrow mt-12">Experience</h3>
        <ul class="mt-5 space-y-3">
          {experience.map((e) => (
            <li class="card p-4 sm:p-5">
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <h4 class="font-medium text-fg">{e.role}</h4>
                <span class="shrink-0 font-mono text-xs text-fg-subtle">{e.period}</span>
              </div>
              <p class="mt-1 text-sm text-fg-muted">{e.org}</p>
              <p class="mt-2 text-sm leading-relaxed text-fg-subtle">{e.note}</p>
            </li>
          ))}
        </ul>
      </>
    )
  }

  <h3 class="eyebrow mt-12">Education &amp; certifications</h3>
  <ul class="mt-5 grid gap-3 sm:grid-cols-2">
    {
      education.map((e) => (
        <li class="card flex gap-4 p-4 sm:p-5">
          {/* Official marks are dark-on-light, so they sit on a white tile rather than
              being inverted into something that is no longer the institution's logo. */}
          <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md bg-white p-1.5">
            <img src={e.logo} alt={`${e.institution} logo`} class="max-h-full max-w-full object-contain" loading="lazy" />
          </span>
          <div class="min-w-0">
            <h4 class="font-medium leading-snug text-fg">{e.title}</h4>
            <p class="mt-0.5 text-sm text-fg-muted">{e.institution}</p>
            <p class="mt-1 font-mono text-xs text-fg-subtle">{e.period}</p>
            <p class="mt-2 text-sm leading-relaxed text-fg-subtle">{e.note}</p>
            {e.href && (
              <a
                href={e.href}
                rel="noopener"
                class="link mt-2 inline-block text-sm"
                data-umami-event="credential-click"
                data-umami-event-credential={e.title}
              >
                View certificate
              </a>
            )}
          </div>
        </li>
      ))
    }
  </ul>
</section>
