---
import { site } from '../data/profile';
import github from '../data/github.json';

const updated = new Date(github.generated_at).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<section id="contact" aria-labelledby="contact-h" class="wrap py-16 sm:py-20">
  <h2 id="contact-h" class="eyebrow">Contact</h2>

  <p class="mt-3 max-w-2xl text-lg leading-relaxed text-fg">
    Open to research collaborations, internships, and open-source work — in machine learning, systems
    programming, or network engineering.
  </p>

  <!-- The old page had a "form" that just opened a mailto: with an empty body. Real
       addresses, plainly listed, are more useful and one click shorter. -->
  <ul class="mt-8 space-y-2">
    {
      site.emails.map((e) => (
        <li class="flex flex-wrap items-baseline gap-x-3">
          <span class="w-16 shrink-0 font-mono text-xs text-fg-subtle">{e.label}</span>
          <a
            href={`mailto:${e.address}`}
            class="link font-mono text-sm"
            data-umami-event="email-click"
            data-umami-event-inbox={e.label.toLowerCase()}
          >
            {e.address}
          </a>
        </li>
      ))
    }
  </ul>

  <div class="mt-8 flex flex-wrap gap-3">
    {
      site.socials.map((s) => (
        <a
          href={s.url}
          rel="noopener"
          class="rounded-md border border-line-hi px-4 py-2 text-sm text-fg-muted transition-colors hover:border-accent/60 hover:text-accent"
          data-umami-event="social-click"
          data-umami-event-network={s.name.toLowerCase()}
        >
          {s.name}
        </a>
      ))
    }
  </div>

  <footer class="mt-20 border-t border-line pt-6">
    <div class="flex flex-wrap items-center justify-between gap-3 text-xs text-fg-subtle">
      <p>© {new Date().getFullYear()} {site.name} · Quito, Ecuador</p>
      <p class="font-mono">Last updated {updated}</p>
    </div>
    <p class="mt-4 font-mono text-xs text-fg-subtle">Knowledge is not just power — it is freedom.</p>
  </footer>
</section>
